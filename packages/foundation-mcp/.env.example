# EVM address to receive payments for all services (can override per service below)
DEFAULT_PAY_TO=0xYourEVMAddressHere

# Per-service pay-to overrides (optional — defaults to DEFAULT_PAY_TO)
# ARTICLE_PAY_TO=0x...
# LLM_PAY_TO=0x...
# CHAIN_RPC_PAY_TO=0x...

# Service backend URLs (defaults work for local dev)
ARTICLE_SERVICE_URL=http://localhost:5001
LLM_SERVICE_URL=http://localhost:5002
CHAIN_RPC_SERVICE_URL=http://localhost:5003

FACILITATOR_URL=https://x402.semanticpay.io/
PORT=3001
